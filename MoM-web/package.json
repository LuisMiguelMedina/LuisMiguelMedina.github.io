{
  "name": "mo-m-web",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "vite --open",
    "start": "vite --open",
    "build": "tsc --project tsconfig.json --noEmit && vite build",
    "build:gh-pages": "npm run build && node generate-404.js",
    "preview": "vite preview --host",
    "clean": "rimraf dist"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "html"
        }
      }
    ]
  },
  "dependencies": {
    "bootstrap": "^5.3.8",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "rimraf": "^6.0.1",
    "sass": "^1.100.0",
    "typescript": "~5.9.2",
    "vite": "^8.0.14"
  }
}
